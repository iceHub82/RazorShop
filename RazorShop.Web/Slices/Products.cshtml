@inherits RazorSlice<ProductsVm>

<section id="section" class="py-5">
    <div class="container px-4 px-lg-5 mt-5">
        <div class="row gx-4 gx-lg-5 row-cols-2 row-cols-md-3 row-cols-xl-4 justify-content-center">
            @foreach (var product in Model.Products!)
            {
                <div class="col mb-5">
                    <div class="card h-100">
                        <a href="/Product/@product.Id"
                           hx-get="/Product/@product.Id"
                           hx-trigger="click"
                           hx-target="#section"
                           hx-push-url="true"
                           hx-swap="outerHTML">
                           <img width="260" height="330" loading="lazy" class="card-img-top img-fluid" src="/products/@product.Id/main/@($"{product.Id}_listing.webp?v={product.TicksStamp}")" alt="@product.Name" />
                           <div class="card-body p-4">
                               <div class="text-start">
                                   <h2 class="h5 fw-bolder">@product.Name</h2>
                                   @product.Price
                               </div>
                           </div>
                       </a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>