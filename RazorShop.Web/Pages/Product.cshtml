@inherits RazorSlice<ProductVm>
@implements IUsesLayout<_Layout, LayoutModel>

@(await RenderPartialAsync<Product, ProductVm>(Model))

@functions {
    public LayoutModel LayoutModel => new() {
        Title = $"{Model.Name} | Artform.dk",
        Description = Truncate(Model.Description ?? $"{Model.Name} – kunstvare fra Artform.dk.", 155),
        JsonLd = Model.JsonLd,
        Image = $"/products/{Model.Id}/main/{Model.Id}_product.webp",
        HasHeader = false
    };

    private static string Truncate(string text, int max)
        => text.Length <= max ? text : text.Substring(0, max - 1).TrimEnd() + "…";
}