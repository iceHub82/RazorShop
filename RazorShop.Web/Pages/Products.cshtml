@inherits RazorSlice<ProductsVm>
@implements IUsesLayout<_Layout, LayoutModel>

@(await RenderPartialAsync<Products, ProductsVm>(Model))

@functions {
    public LayoutModel LayoutModel => new() {
        Title = Model.Category == null
            ? "Alle produkter | Artform.dk"
            : $"{Model.Category} | Artform.dk",
        Description = Model.Category == null
            ? "Se hele udvalget af plottede tegninger og kunst-T-shirts hos Artform.dk."
            : $"Udvalg af {Model.Category} hos Artform.dk – generativ kunst og håndlavede motiver.",
        HasHeader = true
    };
}